ENVIRONMENT=development
DATABASE_URL=sqlite:///./policyflow.db
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_DISPLAY_NAME=系统管理员
BOOTSTRAP_ADMIN_PASSWORD=replace-on-first-run
UPLOAD_DIR=uploads
RAG_WORKSPACE_DIR=rag_workspaces
MAX_UPLOAD_SIZE_MB=20

# Optional bootstrap model provider. Providers can also be configured at runtime
# from Settings without restarting the backend.
LLM_PROVIDER_NAME=default-openai-compatible
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY_ENV=OPENAI_API_KEY
LLM_CHAT_MODEL=your-chat-model
LLM_EMBEDDING_MODEL=your-embedding-model
LLM_EMBEDDING_DIM=1536
LLM_TIMEOUT_SECONDS=120
